{
  "version": 2,
  "routes": [
    { "src": "/api/summarise", "dest": "/api/summarise.py" },
    { "src": "/api/review", "dest": "/api/log.py" },
    { "src": "/api/reviews", "dest": "/api/log.py" },
    { "src": "/api/log/update", "dest": "/api/log.py" },
    { "src": "/api/log", "dest": "/api/log.py" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
